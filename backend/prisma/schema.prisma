generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id                 Int            @id @default(autoincrement())
  roomCode           String         @unique
  topicMode          String         @default("free")
  themeText          String
  turnLimit          Int            @default(20)
  currentTurn        Int            @default(0)
  currentPlayerIndex Int            @default(0)
  turnStartedAt      DateTime?
  phase              String         @default("waiting")
  phaseStartedAt     DateTime?
  phaseEndsAt        DateTime?
  activeQuestionId   Int?
  hasPassword        Boolean        @default(false)
  passwordHash       String?
  status             String         @default("waiting")
  winnerPlayerId     Int?
  winnerName         String?
  correctTopic       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  players            RoomPlayer[]
  gameLogs           GameLog[]
  questions          GameQuestion[]
}

model RoomPlayer {
  id             Int      @id @default(autoincrement())
  roomId         Int
  playerName     String
  playerColor    String
  isHost         Boolean  @default(false)
  turnOrder      Int?
  submittedTopic String?
  assignedTopic  String?
  joinedAt       DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

model GameLog {
  id         Int      @id @default(autoincrement())
  roomId     Int
  playerId   Int
  playerName String
  actionType String
  content    String
  turnNumber Int
  createdAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id])
}

model GameQuestion {
  id               Int                  @id @default(autoincrement())
  roomId           Int
  playerId         Int
  playerName       String
  questionText     String
  turnNumber       Int
  status           String               @default("answering")
  startedAt        DateTime             @default(now())
  answerDeadlineAt DateTime
  resultDeadlineAt DateTime?
  answers          GameQuestionAnswer[]

  room Room @relation(fields: [roomId], references: [id])
}

model GameQuestionAnswer {
  id         Int      @id @default(autoincrement())
  questionId Int
  playerId   Int
  playerName String
  answerKbn  String
  createdAt  DateTime @default(now())

  question GameQuestion @relation(fields: [questionId], references: [id])

  @@unique([questionId, playerId])
}
